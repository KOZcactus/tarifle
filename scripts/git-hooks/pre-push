#!/usr/bin/env bash
# Tarifle pre-push hook: blocks push if `npm run lint` OR
# `npm run content:validate` fails, or if an em-dash (U+2014) slipped
# into staged/committed files that ship to users.
#
# CI runs `next lint` + `content:validate` (muğlak ifade + Zod + semantik
# checks) + tsc + vitest + build. Lint ve validate hızlı (~2-5s); lokalde
# yakalamak GitHub Actions round-trip'ini kurtarır. Tsc + tests + build
# çok daha pahalı, onları hook'a katmıyoruz — her commit'te 1-2 dk
# beklemek push akışını öldürür.
#
# Activation (one-time, per clone):
#   npm run setup:hooks
#
# Bypass in emergencies:
#   git push --no-verify
set -e

echo "🔍 pre-push: npm run lint"
if ! npm run --silent lint; then
  echo ""
  echo "❌ pre-push: lint failed. Fix the errors above or bypass with --no-verify."
  exit 1
fi

echo "✅ pre-push: lint clean"

echo "🔍 pre-push: npm run content:validate"
if ! npm run --silent content:validate; then
  echo ""
  echo "❌ pre-push: content:validate failed (ERROR'lar — muğlak ifade, kcal, alkol tag vs.)."
  echo "   Fix the ERROR lines above or bypass with --no-verify."
  exit 1
fi

echo "✅ pre-push: content:validate clean"

# JSON duplicate top-level key guard (oturum 19 PWA i18n bug dersi).
# messages/*.json'da duplicate top-level key sessizce override ediyor,
# tum namespace kayboluyor. Oturum 19'da 'home' namespace iki kere
# yazildi, prod'da raw key'ler goruldu. Bu guard aynı hatayi onler.
echo "🔍 pre-push: messages JSON duplicate key guard"
if ! node scripts/check-json-dupe-keys.mjs; then
  echo ""
  echo "   Duplicate top-level key var, JSON.parse override eder."
  echo "   Fix: ikinci key'i birinci namespace icine tasi."
  exit 1
fi

echo "✅ pre-push: messages JSON clean"

# Em-dash (U+2014) guard.
# User-facing metinlerde em-dash "AI yazdı" hissi veriyor, kural olarak
# yasak (bkz. AGENTS.md "Em-dash yasak"). Birkaç dosya istisna:
# - AGENTS.md / docs/CODEX_BATCH_BRIEF.md / docs/EM_DASH_CLEANUP.md:
#   kural açıklaması, karakter referansı (— U+2014) göstermek zorunda.
# - docs/PROJECT_STATUS.md / docs/CHANGELOG.md: tarihsel kayıt, eski
#   commit başlıklarında kalabilir.
# - test-results/: Playwright auto-gen, gitignore'da.
# Kalan her yerde grep 0 dönmeli.
echo "🔍 pre-push: em-dash (U+2014) guard"
if ! node scripts/check-emdash.mjs; then
  echo ""
  echo "   Kural: AGENTS.md em-dash yasak. Bypass: git push --no-verify."
  exit 1
fi

echo "✅ pre-push: em-dash guard clean"

# Allergen source guard.
# Seed (scripts/seed-recipes.ts) ingredient listesi ile allergens alanını
# karşılaştırır. 'over-tag' (allergen tag var, match eden ingredient yok)
# veya 'missing' (ingredient match ediyor, allergen tag yok) durumunda
# blocklar. Baseline 4 edge case (check-allergen-source.ts SKIP_FINDINGS)
# hariç. Yeni batch'te allergen-ingredient uyuşmazlığı eklenirse push
# durur. Tarama ~2s, DB'siz.
echo "🔍 pre-push: allergen source guard"
if ! npx tsx scripts/check-allergen-source.ts; then
  echo ""
  echo "   Fix via scripts/fix-critical-allergens-*.ts or remove-over-tagged-allergens.ts."
  echo "   Bypass: git push --no-verify"
  exit 1
fi

echo "✅ pre-push: allergen source guard clean"

# TypeScript compile check.
# Oturum 11 kapanışında fark edildi: pre-push lint + validate + em-dash
# + allergen hepsini geçiyordu ama tsc --noEmit CI'da fail ediyordu
# (scripts/restore-missing-slugs-to-seed.ts Prisma Decimal → number
# assign hatası). 36+ commit CI kırmızı gitti + Vercel deploy bozuldu.
# Bu katman tsc'yi pre-push'a kilitliyor, ~10-15s maliyet kabul
# edilebilir (CI round-trip kaybından çok daha iyi).
echo "🔍 pre-push: tsc --noEmit (TypeScript compile)"
if ! npx tsc --noEmit --pretty false; then
  echo ""
  echo "❌ pre-push: tsc failed. CI build'i fail eder, Vercel deploy bozulur."
  echo "   Fix TS errors above, or bypass with --no-verify (riskli)."
  exit 1
fi

echo "✅ pre-push: tsc clean"
