{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude)docs/' ':(exclude)memory/' ':(exclude)*.md'",
  "crons": [
    {
      "path": "/api/cron/indexnow",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/audit-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/leaderboard",
      "schedule": "0 5 * * 1"
    }
  ]
}
