generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum RecipeType {
  YEMEK
  TATLI
  ICECEK
  KOKTEYL
  APERATIF
  SALATA
  CORBA
  KAHVALTI
  ATISTIRMALIK
  SOS
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  REJECTED
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  REJECTED
}

enum ReportTarget {
  VARIATION
  COMMENT
}

enum ReportReason {
  SPAM
  PROFANITY
  MISLEADING
  HARMFUL
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum VideoJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum BadgeKey {
  EMAIL_VERIFIED
  FIRST_VARIATION
  POPULAR_VARIATION
  RECIPE_COLLECTOR
}

/**
 * EU Food Information Regulation "big 10" adapted for Turkish recipes.
 * - GLUTEN covers wheat/rye/barley/oats (un, ekmek, bulgur, makarna)
 * - KUSUYEMIS is tree nuts (ceviz, badem, fındık, antep fıstığı)
 * - YER_FISTIGI is peanuts — separated from tree nuts because the
 *   allergies are clinically distinct
 * - DENIZ_URUNLERI bundles fish + crustaceans + molluscs (balık/karides/midye)
 *
 * Lupin, celery outside of stock, sulphites-in-wine are omitted as they're
 * rarely relevant to Turkish home cooking; we can extend this enum later if
 * a specific recipe needs a flag that doesn't fit the current set.
 */
enum Allergen {
  GLUTEN
  SUT
  YUMURTA
  KUSUYEMIS
  YER_FISTIGI
  SOYA
  DENIZ_URUNLERI
  SUSAM
  KEREVIZ
  HARDAL
}

enum NotificationType {
  VARIATION_LIKED
  VARIATION_HIDDEN
  VARIATION_APPROVED
  REPORT_RESOLVED
  BADGE_AWARDED
  SYSTEM
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?   @db.VarChar(100)
  username         String    @unique @db.VarChar(50)
  email            String    @unique @db.VarChar(255)
  emailVerified    DateTime?
  passwordHash     String?   @db.VarChar(255)
  avatarUrl        String?   @db.Text
  bio              String?   @db.VarChar(300)
  role             Role      @default(USER)
  isVerified       Boolean   @default(false)
  kvkkAccepted     Boolean   @default(false)
  kvkkVersion      String?   @db.VarChar(20)
  kvkkDate         DateTime?
  termsVersion     String?   @db.VarChar(20)
  marketingConsent Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  recipes           Recipe[]
  variations        Variation[]
  likes             Like[]
  bookmarks         Bookmark[]
  collections       Collection[]
  shoppingLists     ShoppingList[]
  badges            UserBadge[]
  notifications     Notification[]
  reports           Report[]
  moderationActions ModerationAction[]
  auditLogs         AuditLog[]
  mediaAssets       MediaAsset[]
  accounts          Account[]
  sessions          Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/**
 * Password reset tokens. Separate from VerificationToken so the two flows
 * can have independent TTLs (reset is shorter, 1h) and so consuming one
 * does not accidentally invalidate the other. `identifier` is the normalized
 * email; tokens are base64url random, 32 bytes.
 */
model PasswordResetToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
  @@map("password_reset_tokens")
}

model Category {
  id          String     @id @default(cuid())
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  emoji       String?    @db.VarChar(10)
  description String?    @db.Text
  parentId    String?
  sortOrder   Int        @default(0)
  imageUrl    String?    @db.Text
  createdAt   DateTime   @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  recipes  Recipe[]

  @@map("categories")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique @db.VarChar(50)
  slug      String      @unique @db.VarChar(50)
  createdAt DateTime    @default(now())

  recipeTags RecipeTag[]

  @@map("tags")
}

model Recipe {
  id                String       @id @default(cuid())
  title             String       @db.VarChar(200)
  slug              String       @unique @db.VarChar(200)
  description       String       @db.Text
  emoji             String?      @db.VarChar(20)
  categoryId        String
  type              RecipeType
  difficulty        Difficulty
  prepMinutes       Int
  cookMinutes       Int
  totalMinutes      Int
  servingCount      Int
  averageCalories   Int?
  protein           Decimal?     @db.Decimal(5, 1)
  carbs             Decimal?     @db.Decimal(5, 1)
  fat               Decimal?     @db.Decimal(5, 1)
  imageUrl          String?      @db.Text
  videoUrl          String?      @db.Text
  isFeatured        Boolean      @default(false)
  status            RecipeStatus @default(PUBLISHED)
  viewCount         Int          @default(0)
  tipNote           String?      @db.Text
  servingSuggestion String?      @db.Text
  authorId          String?
  // Allergens present in this recipe. Postgres enum array — queryable with
  // Prisma's hasSome / hasNone / has. Default empty; retrofit script or
  // explicit Codex-provided list populates it. A GIN index covers the array
  // so "bu alerjenleri iceren tarifleri gizle" filter stays fast.
  allergens         Allergen[]   @default([])
  // Optional translations bucket. Shape (see docs/RECIPE_FORMAT.md):
  //   { en?: { title, description, tipNote, servingSuggestion,
  //            ingredients: [{sortOrder, name}],
  //            steps: [{stepNumber, instruction, tip?}] },
  //     de?: {...} }
  // Primary language is always Turkish (the bare columns). Translations
  // are opt-in per-locale; the UI language toggle (Faz 3) will read this
  // JSON at render time. Stored as JSONB so we can add languages without
  // a schema migration. NULL when no translations exist yet.
  translations      Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  category        Category           @relation(fields: [categoryId], references: [id])
  author          User?              @relation(fields: [authorId], references: [id])
  ingredients     RecipeIngredient[]
  steps           RecipeStep[]
  tags            RecipeTag[]
  variations      Variation[]
  bookmarks       Bookmark[]
  collectionItems CollectionItem[]
  videoJobs       VideoJob[]

  @@index([categoryId])
  @@index([status])
  @@index([type])
  @@index([isFeatured])
  // Composite indexes for actually-issued listing queries. Ordered so the
  // leading predicate (status) covers most reads. Avoid speculative wide
  // indexes — write cost adds up and Postgres prefers narrow scans.
  @@index([status, createdAt])
  @@index([status, totalMinutes])
  @@index([status, viewCount])
  // GIN on the allergens enum-array so `hasSome` filters (used by the
  // "icermesin" allergen filter on /tarifler) stay fast once the catalog
  // grows to 500+ recipes. Postgres GIN is the right access method for
  // array containment — btree can't index arrays efficiently.
  @@index([allergens], type: Gin)
  @@map("recipes")
}

model RecipeIngredient {
  id             String   @id @default(cuid())
  recipeId       String
  name           String   @db.VarChar(200)
  amount         String   @db.VarChar(50)
  unit           String?  @db.VarChar(50)
  sortOrder      Int      @default(0)
  isOptional     Boolean  @default(false)
  caloriePerUnit Decimal? @db.Decimal(7, 2)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_ingredients")
}

model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  stepNumber   Int
  instruction  String  @db.Text
  tip          String? @db.Text
  imageUrl     String? @db.Text
  timerSeconds Int?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tagId])
  @@map("recipe_tags")
}

model Variation {
  id          String        @id @default(cuid())
  recipeId    String
  authorId    String
  miniTitle   String        @db.VarChar(200)
  description String?       @db.Text
  ingredients Json
  steps       Json
  notes       String?       @db.Text
  imageUrl    String?       @db.Text
  likeCount   Int           @default(0)
  reportCount Int           @default(0)
  status      ContentStatus @default(PUBLISHED)
  // Comma-separated PreflightFlag codes (see lib/moderation/preflight.ts).
  // Null = clean auto-publish; non-null = rule-based flags that triggered
  // PENDING_REVIEW. Admins render the chips in the review queue.
  moderationFlags String?   @db.VarChar(200)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id])
  author User   @relation(fields: [authorId], references: [id])
  likes  Like[]

  @@index([recipeId])
  @@index([authorId])
  // Listing recipes' variations (only PUBLISHED, sorted by likes)
  @@index([recipeId, status, likeCount])
  // Profile variation feed (owner vs public read)
  @@index([authorId, status, createdAt])
  @@map("variations")
}

model Like {
  id          String   @id @default(cuid())
  userId      String
  variationId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  variation Variation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@unique([userId, variationId])
  @@map("likes")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@map("bookmarks")
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetType  ReportTarget
  targetId    String
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  @@index([status])
  @@index([status, createdAt])
  @@index([targetType, targetId, status])
  // A user can only report a given target once
  @@unique([reporterId, targetType, targetId])
  @@map("reports")
}

model ModerationAction {
  id          String   @id @default(cuid())
  moderatorId String
  targetType  String   @db.VarChar(50)
  targetId    String
  action      String   @db.VarChar(20)
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  moderator User @relation(fields: [moderatorId], references: [id])

  @@map("moderation_actions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   @db.VarChar(100)
  targetType String?  @db.VarChar(50)
  targetId   String?
  metadata   Json?
  ipAddress  String?  @db.VarChar(45)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model MediaAsset {
  id         String    @id @default(cuid())
  uploaderId String?
  type       MediaType
  url        String    @db.Text
  publicId   String?   @db.VarChar(255)
  width      Int?
  height     Int?
  sizeBytes  Int?
  mimeType   String?   @db.VarChar(50)
  createdAt  DateTime  @default(now())

  uploader User? @relation(fields: [uploaderId], references: [id])

  @@map("media_assets")
}

model VideoJob {
  id              String         @id @default(cuid())
  recipeId        String
  provider        String         @db.VarChar(50)
  status          VideoJobStatus @default(QUEUED)
  prompt          String?        @db.Text
  inputImageUrl   String?        @db.Text
  outputUrl       String?        @db.Text
  errorMessage    String?        @db.Text
  costEstimate    Decimal?       @db.Decimal(8, 4)
  durationSeconds Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("video_jobs")
}

model NutritionData {
  id              String   @id @default(cuid())
  name            String   @unique @db.VarChar(200)
  caloriesPer100g Decimal  @db.Decimal(7, 2)
  proteinPer100g  Decimal  @db.Decimal(5, 2)
  carbsPer100g    Decimal  @db.Decimal(5, 2)
  fatPer100g      Decimal  @db.Decimal(5, 2)
  defaultUnit     String?  @db.VarChar(50)
  gramsPerUnit    Decimal? @db.Decimal(7, 2)
  source          String?  @db.VarChar(100)

  @@map("nutrition_data")
}

// ─── COLLECTIONS & SHOPPING LIST (Faz 2) ─────────────────

model Collection {
  id            String   @id @default(cuid())
  userId        String
  name          String   @db.VarChar(100)
  slug          String   @db.VarChar(120)
  description   String?  @db.VarChar(500)
  emoji         String?  @db.VarChar(10)
  coverImageUrl String?  @db.Text
  isPublic      Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@unique([userId, slug])
  @@index([userId])
  // Profile collection feed (owner or public viewers, sorted)
  @@index([userId, isPublic, sortOrder, createdAt])
  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  recipeId     String
  note         String?  @db.VarChar(300)
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, recipeId])
  @@index([recipeId])
  @@index([collectionId, addedAt])
  @@map("collection_items")
}

model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Alışveriş Listem") @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String   @id @default(cuid())
  shoppingListId String
  name           String   @db.VarChar(200)
  amount         String?  @db.VarChar(50)
  unit           String?  @db.VarChar(50)
  isChecked      Boolean  @default(false)
  sortOrder      Int      @default(0)
  sourceRecipeId String?
  createdAt      DateTime @default(now())

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@index([shoppingListId])
  @@index([shoppingListId, isChecked, sortOrder, createdAt])
  @@map("shopping_list_items")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  key       BadgeKey
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_badges")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String?          @db.Text
  // Optional in-app target path (e.g. "/tarif/foo" or "/profil/me"). Never
  // trusted as an external URL — the UI renders it through <Link>.
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The hot paths are: count unread for bell badge, list most-recent-first.
  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
