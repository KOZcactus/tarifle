{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@tarifle/shared": ["../../packages/shared/src"],
      "@tarifle/api-client": ["../../packages/api-client/src"],
      "@tarifle/design-tokens": ["../../packages/design-tokens/src"],
      "@tarifle/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
