# Site
NEXT_PUBLIC_SITE_URL="https://tarifle.vercel.app"

# Veritabani
DATABASE_URL="postgresql://user:pass@host:5432/tarifle?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI (Faz 2)
AI_PROVIDER="claude"
ANTHROPIC_API_KEY=""

# Resend (e-posta gonderimi — yoksa ConsoleEmailProvider fallback)
RESEND_API_KEY=""
RESEND_FROM="Tarifle <noreply@tarifle.app>"

# Upstash Redis (rate limiting — yoksa fail-open no-op)
# console.upstash.com -> Redis -> Create Database -> REST tab
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Pinterest domain verification (opsiyonel — rich pin + analytics icin)
# pinterest.com/settings/claim -> Websites -> Claim -> "Add HTML tag"
# Verilen tag icindeki content degerini buraya yapistirin.
# Yoksa meta tag eklenmez (sessiz no-op).
PINTEREST_DOMAIN_VERIFY=""
