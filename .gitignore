# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
test-results/
playwright-report/

# Claude Code — user-specific harness files (permissions, dev launch config)
# contain local preferences and may include env-inlined commands with secrets
.claude/settings.local.json
.claude/launch.json

# Codex / Mod B scratchpad — tarif Mod B çevirisi sırasında Codex
# tmp_batch*.txt gibi scratch dosyalar bırakıyor. Bunların repo'ya
# girmemesi için pattern. `git add -A` refleksiyle yanlışlıkla
# karışmasınlar (bkz. feat(blog) commit 9e196fc içinde 4 tmp dosya
# sızdı — bu ignore pattern eklendikten sonra tekrarı olmaz).
tmp_*
tmp-*
