generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum RecipeType {
  YEMEK
  TATLI
  ICECEK
  KOKTEYL
  APERATIF
  SALATA
  CORBA
  KAHVALTI
  ATISTIRMALIK
  SOS
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  REJECTED
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  REJECTED
}

enum ReportTarget {
  VARIATION
  COMMENT
  REVIEW
}

enum ReportReason {
  SPAM
  PROFANITY
  MISLEADING
  HARMFUL
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum VideoJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum BadgeKey {
  EMAIL_VERIFIED
  FIRST_VARIATION
  POPULAR_VARIATION
  RECIPE_COLLECTOR
  // Faz 1 topluluk rozetleri (oturum 12+):
  // Her biri UserBadge tablosunda atanır, haftalık cron script'i
  // yeniden değerlendirir. POPULAR_VARIATION + EDITOR_CHOICE ayrı:
  // POPULAR 10+ beğeni aldıysa, EDITOR_CHOICE ise moderator seçimi
  // (skor bonusu ×10).
  EXPERIENCED // 5+ uyarlama
  PHOTOGRAPHER // 10+ tarif fotoğrafı upload
  CATEGORY_MASTER // Aynı kategoride 5+ uyarlama
  EDITOR_CHOICE // Moderator tarafından "topluluk seçimi" onayı
  WEEKLY_TOP_10 // Haftalık leaderboard top 10 (son 7 gün)
  MONTHLY_TOP_10 // Aylık leaderboard top 10 (son 30 gün)
  ALL_TIME_TOP_50 // Tüm zamanlar top 50
}

/**
 * EU Food Information Regulation "big 10" adapted for Turkish recipes.
 * - GLUTEN covers wheat/rye/barley/oats (un, ekmek, bulgur, makarna)
 * - KUSUYEMIS is tree nuts (ceviz, badem, fındık, antep fıstığı)
 * - YER_FISTIGI is peanuts — separated from tree nuts because the
 * allergies are clinically distinct
 * - DENIZ_URUNLERI bundles fish + crustaceans + molluscs (balık/karides/midye)
 * Lupin, celery outside of stock, sulphites-in-wine are omitted as they're
 * rarely relevant to Turkish home cooking; we can extend this enum later if
 * a specific recipe needs a flag that doesn't fit the current set.
 */
enum Allergen {
  GLUTEN
  SUT
  YUMURTA
  KUSUYEMIS
  YER_FISTIGI
  SOYA
  DENIZ_URUNLERI
  SUSAM
  KEREVIZ
  HARDAL
}

enum NotificationType {
  VARIATION_LIKED
  VARIATION_HIDDEN
  VARIATION_APPROVED
  REVIEW_HIDDEN
  REVIEW_APPROVED
  REPORT_RESOLVED
  BADGE_AWARDED
  FOLLOWED
  NEW_VARIATION_FROM_FOLLOWED
  SYSTEM
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  name               String?    @db.VarChar(100)
  username           String     @unique @db.VarChar(50)
  email              String     @unique @db.VarChar(255)
  emailVerified      DateTime?
  passwordHash       String?    @db.VarChar(255)
  avatarUrl          String?    @db.Text
  bio                String?    @db.VarChar(300)
  role               Role       @default(USER)
  isVerified         Boolean    @default(false)
  kvkkAccepted       Boolean    @default(false)
  kvkkVersion        String?    @db.VarChar(20)
  kvkkDate           DateTime?
  termsVersion       String?    @db.VarChar(20)
  marketingConsent   Boolean    @default(false)
  deletedAt          DateTime?
  // Suspension — admin action. Null = hesap aktif. Değer varsa giriş yapamaz
  // ve protected action'lar (yorum/uyarlama yazma) bloklanır. Reason
  // moderator'ın kayda aldığı kısa not, kullanıcıya "sebep ekranında"
  // gösterilebilir (opsiyonel ileri iş).
  suspendedAt        DateTime?
  suspendedReason    String?    @db.VarChar(500)
  // Dil tercihi — "tr" default (tüm mevcut kullanıcılar TR sayılır). User
  // ayarlar sayfasında veya navbar selector'da değiştirir. Cookie
  // NEXT_LOCALE + bu alan birlikte çalışır: login'de cookie bu değerle
  // sync'lenir, anonymous user ise sadece cookie kullanılır.
  locale             String     @default("tr") @db.VarChar(5)
  // Kişiselleştirme tercihleri — /ayarlar/tercihler'den kullanıcı seçer,
  // ileride feed/discover filtering'de kullanılacak (MVP bu turda yalnızca
  // saklama + UI; filtering sonraki pass).
  //   - favoriteTags: Tag.slug string'leri ("vejetaryen", "dusuk-kalorili" vs.).
  //     Kullanıcı "bu etiketli tarifleri daha çok görmek isterim" der.
  //   - allergenAvoidances: kaçınılan alerjenler. Listing/detail'de uyarı
  //     gösterebiliriz, filtering'de default noindex-allergens olarak uygula.
  //   - favoriteCuisines: cuisine kod listesi (24 kodtan — tr/it/fr vs.).
  //     "Ağırlıklı Türk + İtalyan görmek isterim" gibi.
  favoriteTags       String[]   @default([])
  allergenAvoidances Allergen[] @default([])
  favoriteCuisines   String[]   @default([])
  // Profil gizlilik tercihleri, /ayarlar/gizlilik'ten kullanıcı seçer.
  // Default: hepsi açık (mevcut davranışla geriye uyumlu). Owner kendi
  // profilinde her zaman görür, başkalarına görünüm gizlilik ayarına bağlı.
  //   - showChefScore: false ise profil chip + leaderboard'da gizli (opt-out)
  //   - showActivity: false ise "Son aktiviteler" timeline gizli
  //   - showFollowCounts: false ise takipçi/takip sayıları + listeler gizli
  showChefScore      Boolean    @default(true)
  showActivity       Boolean    @default(true)
  showFollowCounts   Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  recipes                 Recipe[]
  variations              Variation[]
  likes                   Like[]
  bookmarks               Bookmark[]
  collections             Collection[]
  shoppingLists           ShoppingList[]
  mealPlans               MealPlan[]
  newsletterSubscriptions NewsletterSubscription[]
  recipePhotos            RecipePhoto[]
  badges                  UserBadge[]
  notifications           Notification[]
  reports                 Report[]
  reviews                 Review[]
  moderationActions       ModerationAction[]
  auditLogs               AuditLog[]
  mediaAssets             MediaAsset[]
  accounts                Account[]
  sessions                Session[]
  // Takip/feed V1 — kullanıcı hem takipçisi (following ilişkisinde follower)
  // hem de takip edilen (followers ilişkisinde following) taraf olur. İki
  // named relation Prisma'nın tek modelde iki yönü ayırt etmesi için zorunlu.
  followers               Follow[]                 @relation("following")
  following               Follow[]                 @relation("follower")
  pantryItems             UserPantryItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/**
 * Password reset tokens. Separate from VerificationToken so the two flows
 * can have independent TTLs (reset is shorter, 1h) and so consuming one
 * does not accidentally invalidate the other. `identifier` is the normalized
 * email; tokens are base64url random, 32 bytes.
 */
model PasswordResetToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
  @@map("password_reset_tokens")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  emoji       String?  @db.VarChar(10)
  description String?  @db.Text
  parentId    String?
  sortOrder   Int      @default(0)
  imageUrl    String?  @db.Text
  createdAt   DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  recipes  Recipe[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now())

  recipeTags RecipeTag[]

  @@map("tags")
}

model Recipe {
  id                String                   @id @default(cuid())
  title             String                   @db.VarChar(200)
  slug              String                   @unique @db.VarChar(200)
  description       String                   @db.Text
  emoji             String?                  @db.VarChar(20)
  categoryId        String
  type              RecipeType
  difficulty        Difficulty
  prepMinutes       Int
  cookMinutes       Int
  totalMinutes      Int
  servingCount      Int
  averageCalories   Int?
  protein           Decimal?                 @db.Decimal(5, 1)
  carbs             Decimal?                 @db.Decimal(5, 1)
  fat               Decimal?                 @db.Decimal(5, 1)
  imageUrl          String?                  @db.Text
  videoUrl          String?                  @db.Text
  isFeatured        Boolean                  @default(false)
  status            RecipeStatus             @default(PUBLISHED)
  viewCount         Int                      @default(0)
  tipNote           String?                  @db.Text
  servingSuggestion String?                  @db.Text
  authorId          String?
  // Allergens present in this recipe. Postgres enum array — queryable with
  // Prisma's hasSome / hasNone / has. Default empty; retrofit script or
  // explicit Codex-provided list populates it. A GIN index covers the array
  // so "bu alerjenleri iceren tarifleri gizle" filter stays fast.
  allergens         Allergen[]               @default([])
  // Cuisine origin code — one of the 14 supported codes defined in
  // `src/lib/cuisines.ts` (tr, it, fr, es, gr, jp, cn, kr, th, in, mx,
  // us, me, ma). NULL for recipes not yet tagged; the retrofit script
  // or explicit Codex labelling populates it. Validated by Zod in the
  // seed schema, not by a Prisma enum — adding a new cuisine (e.g.
  // Vietnamese) only requires updating the constants file + Zod, no
  // migration needed.
  cuisine           String?                  @db.VarChar(30)
  // Hunger bar score, 1-10 integer, Minecraft-esin tokluk göstergesi.
  // Porsiyon başı hesap (`averageCalories` + `protein` + `carbs` + `fat` +
  // ingredient fiber proxy). Formül ve retrofit için src/lib/hunger-bar.ts
  // + scripts/retrofit-hunger-bar.ts. Null = hesaplanmamış (retrofit
  // sonrası dolacak), UI tarafında fallback default 5. Seed opsiyonel
  // override edebilir (manuel karar gerektiren kenarlar için).
  hungerBar         Int?
  // Optional translations bucket. Shape (see docs/RECIPE_FORMAT.md):
  //   { en?: { title, description, tipNote, servingSuggestion,
  //            ingredients: [{sortOrder, name}],
  //            steps: [{stepNumber, instruction, tip?}] },
  //     de?: {...} }
  // Primary language is always Turkish (the bare columns). Translations
  // are opt-in per-locale; the UI language toggle (Faz 3) will read this
  // JSON at render time. Stored as JSONB so we can add languages without
  // a schema migration. NULL when no translations exist yet.
  translations      Json?
  // Full-text search vector — populated by a Postgres GENERATED STORED
  // column (see migration `20260415180000_add_fulltext_search`). Prisma
  // cannot generate typed client fields for `tsvector`, so this is
  // opaque to the ORM. /tarifler search reads it via `$queryRaw` with
  // `websearch_to_tsquery('turkish', immutable_unaccent(input))` and
  // `ts_rank_cd` for relevance ordering. Declared here so Prisma won't
  // try to drop the column on future `migrate dev` runs.
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  category        Category           @relation(fields: [categoryId], references: [id])
  author          User?              @relation(fields: [authorId], references: [id])
  ingredients     RecipeIngredient[]
  steps           RecipeStep[]
  tags            RecipeTag[]
  variations      Variation[]
  bookmarks       Bookmark[]
  collectionItems CollectionItem[]
  videoJobs       VideoJob[]
  reviews         Review[]
  mealPlanItems   MealPlanItem[]
  userPhotos      RecipePhoto[]
  viewDaily       RecipeViewDaily[]

  @@index([categoryId])
  @@index([status])
  @@index([type])
  @@index([isFeatured])
  // Composite indexes for actually-issued listing queries. Ordered so the
  // leading predicate (status) covers most reads. Avoid speculative wide
  // indexes — write cost adds up and Postgres prefers narrow scans.
  @@index([status, createdAt])
  @@index([status, totalMinutes])
  @@index([status, viewCount])
  // GIN on the allergens enum-array so `hasSome` filters (used by the
  // "icermesin" allergen filter on /tarifler) stay fast once the catalog
  // grows to 500+ recipes. Postgres GIN is the right access method for
  // array containment — btree can't index arrays efficiently.
  @@index([allergens], type: Gin)
  // Btree on cuisine string — serves `WHERE cuisine IN (...)` inclusion
  // filter on /tarifler. Simple btree is optimal for single-value nullable
  // varchar; no GIN needed (that's for arrays).
  @@index([cuisine])
  // GIN on the generated tsvector column — powers the /tarifler search
  // box. `map:` pins the index name so it matches the manual CREATE INDEX
  // in the fulltext migration and Prisma treats it as already-managed.
  @@index([searchVector], type: Gin, map: "recipes_search_gin")
  @@map("recipes")
}

model RecipeIngredient {
  id             String   @id @default(cuid())
  recipeId       String
  name           String   @db.VarChar(200)
  amount         String   @db.VarChar(50)
  unit           String?  @db.VarChar(50)
  sortOrder      Int      @default(0)
  isOptional     Boolean  @default(false)
  caloriePerUnit Decimal? @db.Decimal(7, 2)
  // Optional section label used by multi-component recipes ("Hamur için",
  // "Şerbet için", "Sos için"). NULL for simple single-component recipes;
  // the UI renders those as a plain list. Convention: "X için" phrasing.
  // Kept as free-text rather than an enum because section names are
  // context-dependent (a pasta has "Sos için", a kebab has "Marine için").
  group          String?  @db.VarChar(80)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Tarif detay sayfası her açılışta "bu tarifin malzemeleri, sortOrder
  // sıralı" sorar. Composite index olmadan Postgres seq scan yapıyor —
  // 306 tarifte <1ms ama 1000+ tarif × ~7 malzeme = 7k+ satırda
  // scan maliyeti milisaniye mertebesinde büyür. FK'de otomatik index
  // yok (Prisma default + Postgres default).
  @@index([recipeId, sortOrder])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  stepNumber   Int
  instruction  String  @db.Text
  tip          String? @db.Text
  imageUrl     String? @db.Text
  timerSeconds Int?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // RecipeIngredient ile aynı hot path: detay sayfası step listesi
  // her açılışta recipeId filter + stepNumber sıralama ile çekilir.
  @@index([recipeId, stepNumber])
  @@map("recipe_steps")
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tagId])
  @@map("recipe_tags")
}

model Variation {
  id              String        @id @default(cuid())
  recipeId        String
  authorId        String
  miniTitle       String        @db.VarChar(200)
  description     String?       @db.Text
  ingredients     Json
  steps           Json
  notes           String?       @db.Text
  imageUrl        String?       @db.Text
  likeCount       Int           @default(0)
  reportCount     Int           @default(0)
  status          ContentStatus @default(PUBLISHED)
  // Comma-separated PreflightFlag codes (see lib/moderation/preflight.ts).
  // Null = clean auto-publish; non-null = rule-based flags that triggered
  // PENDING_REVIEW. Admins render the chips in the review queue.
  moderationFlags String?       @db.VarChar(200)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id])
  author User   @relation(fields: [authorId], references: [id])
  likes  Like[]

  @@index([recipeId])
  @@index([authorId])
  // Listing recipes' variations (only PUBLISHED, sorted by likes)
  @@index([recipeId, status, likeCount])
  // Profile variation feed (owner vs public read)
  @@index([authorId, status, createdAt])
  @@map("variations")
}

model Like {
  id          String   @id @default(cuid())
  userId      String
  variationId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  variation Variation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@unique([userId, variationId])
  @@map("likes")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@map("bookmarks")
}

// Review — kullanıcı tarife 1-5 yıldız + opsiyonel yorum bırakır. Her
// kullanıcı her tarif için en fazla bir review (@@unique). AggregateRating
// JSON-LD için `Recipe.reviews` üzerinden hesaplama:
//   avg(rating), count(*) → schema.org Recipe.aggregateRating
//
// Moderation: Report targetType = REVIEW (yeni enum değeri) ile admin
// gizleyebilir. PENDING_REVIEW status variation sisteminden clone;
// preflight burada yok (review kısa, spam kontrol rate-limit + report
// sistemi yeterli).
model Review {
  id              String        @id @default(cuid())
  userId          String
  recipeId        String
  rating          Int // 1-5, Zod validated
  comment         String?       @db.Text // nullable — sadece rating de atabilir
  status          ContentStatus @default(PUBLISHED)
  // Comma-separated preflight flag codes (see `lib/moderation/preflight-review.ts`).
  // Null when no flags tripped. Mirrors Variation.moderationFlags shape so
  // the admin queue can render both with the same component.
  moderationFlags String?       @db.VarChar(200)
  // Reason recorded by the moderator when status was flipped to HIDDEN.
  // Surfaced to the review author in the `REVIEW_HIDDEN` notification.
  hiddenReason    String?       @db.VarChar(500)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId, status])
  @@index([userId, createdAt])
  @@map("reviews")
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetType  ReportTarget
  targetId    String
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  // A user can only report a given target once
  @@unique([reporterId, targetType, targetId])
  @@index([status])
  @@index([status, createdAt])
  @@index([targetType, targetId, status])
  @@map("reports")
}

model ModerationAction {
  id          String   @id @default(cuid())
  moderatorId String
  targetType  String   @db.VarChar(50)
  targetId    String
  action      String   @db.VarChar(20)
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  moderator User @relation(fields: [moderatorId], references: [id])

  // Newest-first listing (admin moderation log).
  @@index([createdAt(sort: Desc)])
  // "Bu moderator en son ne yaptı" — moderator detail sayfası ileride.
  @@index([moderatorId, createdAt(sort: Desc)])
  // Filter by target type + action — log sayfasındaki chip filtreleri
  @@index([targetType, action, createdAt(sort: Desc)])
  @@map("moderation_actions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   @db.VarChar(100)
  targetType String?  @db.VarChar(50)
  targetId   String?
  metadata   Json?
  ipAddress  String?  @db.VarChar(45)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model MediaAsset {
  id         String    @id @default(cuid())
  uploaderId String?
  type       MediaType
  url        String    @db.Text
  publicId   String?   @db.VarChar(255)
  width      Int?
  height     Int?
  sizeBytes  Int?
  mimeType   String?   @db.VarChar(50)
  createdAt  DateTime  @default(now())

  uploader User? @relation(fields: [uploaderId], references: [id])

  @@map("media_assets")
}

model VideoJob {
  id              String         @id @default(cuid())
  recipeId        String
  provider        String         @db.VarChar(50)
  status          VideoJobStatus @default(QUEUED)
  prompt          String?        @db.Text
  inputImageUrl   String?        @db.Text
  outputUrl       String?        @db.Text
  errorMessage    String?        @db.Text
  costEstimate    Decimal?       @db.Decimal(8, 4)
  durationSeconds Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("video_jobs")
}

model NutritionData {
  id              String   @id @default(cuid())
  name            String   @unique @db.VarChar(200)
  caloriesPer100g Decimal  @db.Decimal(7, 2)
  proteinPer100g  Decimal  @db.Decimal(5, 2)
  carbsPer100g    Decimal  @db.Decimal(5, 2)
  fatPer100g      Decimal  @db.Decimal(5, 2)
  defaultUnit     String?  @db.VarChar(50)
  gramsPerUnit    Decimal? @db.Decimal(7, 2)
  source          String?  @db.VarChar(100)

  @@map("nutrition_data")
}

// ─── COLLECTIONS & SHOPPING LIST (Faz 2) ─────────────────

model Collection {
  id            String    @id @default(cuid())
  userId        String
  name          String    @db.VarChar(100)
  slug          String    @db.VarChar(120)
  description   String?   @db.VarChar(500)
  emoji         String?   @db.VarChar(10)
  coverImageUrl String?   @db.Text
  isPublic      Boolean   @default(false)
  sortOrder     Int       @default(0)
  // Admin gizleme — public koleksiyon uygunsuz içerik bildirilirse
  // admin hideCollection ile timestamp yazar. Owner koleksiyonunu görür
  // (kendi dashboard'ında) ama public listelerden düşer.
  hiddenAt      DateTime?
  hiddenReason  String?   @db.VarChar(500)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@unique([userId, slug])
  @@index([userId])
  // Profile collection feed (owner or public viewers, sorted)
  @@index([userId, isPublic, sortOrder, createdAt])
  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  recipeId     String
  note         String?  @db.VarChar(300)
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, recipeId])
  @@index([recipeId])
  @@index([collectionId, addedAt])
  @@map("collection_items")
}

model ShoppingList {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Alışveriş Listem") @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String   @id @default(cuid())
  shoppingListId String
  name           String   @db.VarChar(200)
  amount         String?  @db.VarChar(50)
  unit           String?  @db.VarChar(50)
  isChecked      Boolean  @default(false)
  sortOrder      Int      @default(0)
  sourceRecipeId String?
  createdAt      DateTime @default(now())

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@index([shoppingListId])
  @@index([shoppingListId, isChecked, sortOrder, createdAt])
  @@map("shopping_list_items")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  key       BadgeKey
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_badges")
}

/// Haftalık menü planlayıcı — kullanıcının 7 gün × 3 öğün tarif
/// seçimini tutar. Her kullanıcının birden fazla planı olabilir
/// (geçmiş haftalar arşivlenir); aktif plan `weekStart` günümüzün
/// haftasına denk gelen kayıttır.
model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  /// Planın başladığı günün 00:00'ı — genelde Pazartesi. Aynı kullanıcı
  /// aynı haftaya birden fazla plan açamaz (@@unique).
  weekStart DateTime @db.Date
  /// Opsiyonel isim — "Yaz menüsü", "Misafir haftası" gibi custom
  /// etiketler için. Default boş, UI placeholder kullanır.
  name      String?  @db.VarChar(100)
  notes     String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealPlanItem[]

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("meal_plans")
}

/// Menü planındaki tek slot — belirli gün + öğün için seçilen tarif.
/// `dayOfWeek` 0-6 (Pazartesi=0 … Pazar=6), `mealType` enum.
model MealPlanItem {
  id         String   @id @default(cuid())
  mealPlanId String
  recipeId   String
  /// 0 = Pazartesi, 6 = Pazar. Week starts on Monday (TR convention).
  dayOfWeek  Int
  mealType   MealType
  servings   Int?     @default(1)
  createdAt  DateTime @default(now())

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  /// Aynı slot (plan × gün × öğün) tekrar eklenemez — yeni seçim
  /// mevcut satırı update eder, duplicate oluşmaz.
  @@unique([mealPlanId, dayOfWeek, mealType])
  @@index([mealPlanId])
  @@index([recipeId])
  @@map("meal_plan_items")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

/// Haftalık newsletter aboneliği — email + status + tokenlar.
/// Double-opt-in: kayıt olunduğunda CONFIRMING status + email ile
/// confirm token gönderilir; kullanıcı tıklayınca ACTIVE'e geçer.
/// Unsubscribe token her mail'in altına gömülür, tıklanınca status
/// UNSUBSCRIBED olur (hard delete yerine soft — yasal audit için).
model NewsletterSubscription {
  id               String                       @id @default(cuid())
  email            String                       @unique @db.VarChar(255)
  status           NewsletterSubscriptionStatus @default(CONFIRMING)
  /// Confirm link token — 24h TTL, tek kullanımlık.
  confirmToken     String?                      @unique @db.VarChar(100)
  confirmTokenAt   DateTime?
  /// Unsubscribe link token — lifetime, tek kullanımlık ama hep aynı
  /// token (GDPR gereği kolay kaldırma).
  unsubscribeToken String                       @unique @db.VarChar(100)
  locale           String                       @default("tr") @db.VarChar(5)
  /// Opsiyonel — logged-in user abone olursa User'a bağlanır. Anonim
  /// aboneliklerde null kalır (email yeterli kimlik).
  userId           String?
  createdAt        DateTime                     @default(now())
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("newsletter_subscriptions")
}

enum NewsletterSubscriptionStatus {
  /// E-posta gönderildi, onay bekliyor (24h pencere).
  CONFIRMING
  /// Onaylandı, mail alıyor.
  ACTIVE
  /// Unsubscribe linkine tıkladı.
  UNSUBSCRIBED
  /// Hard bounce / spam report → otomatik suspend.
  SUSPENDED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String?          @db.Text
  // Optional in-app target path (e.g. "/tarif/foo" or "/profil/me"). Never
  // trusted as an external URL — the UI renders it through <Link>.
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The hot paths are: count unread for bell badge, list most-recent-first.
  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Site-wide duyuru — admin ekler, public header'da banner olarak gösterilir.
// `endsAt` null = süresiz; `startsAt` null = hemen başlar. Variant sütun tipi
// serbest string ama UI bilinen 3 değeri renderlar (info/warning/success).
enum AnnouncementVariant {
  INFO
  WARNING
  SUCCESS
}

model Announcement {
  id        String              @id @default(cuid())
  title     String              @db.VarChar(200)
  body      String?             @db.VarChar(1000)
  link      String?             @db.VarChar(500)
  variant   AnnouncementVariant @default(INFO)
  // Yayın penceresi. Her ikisi de null bırakılırsa duyuru "taslak"
  // gibidir; only startsAt verilirse o andan itibaren süresiz yayın.
  startsAt  DateTime?
  endsAt    DateTime?
  // Kim oluşturdu — audit için; silinmiş user için null kalabilir.
  createdBy String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([startsAt, endsAt])
  @@map("announcements")
}

// Search query log — `/tarifler?q=...` SSR akışında fire-and-forget insert
// edilir. Admin analytics dashboard'da "top search freq" kartı bu tablodan
// beslenir. Normalized bucket (TR lowercase + asciifold) ile "köfte"/
// "KOFTE"/"köftesi" aynı satıra yazılır. user null ise anonim arama.
// 90 gün sonra pruning ayrı bir cron iş — şimdilik sonsuz bekliyor.
model SearchQuery {
  id              String   @id @default(cuid())
  query           String   @db.VarChar(200)
  normalizedQuery String   @db.VarChar(200)
  resultCount     Int
  userId          String?
  createdAt       DateTime @default(now())

  // Top N aggregate query: `normalizedQuery GROUP BY _count DESC WHERE
  // createdAt >= since`. Composite index (normalizedQuery, createdAt)
  // time-windowed group-by için en düşük maliyetli.
  @@index([normalizedQuery, createdAt])
  @@index([createdAt])
  @@map("search_queries")
}

// Günlük görüntülenme sayacı — `/tarif/[slug]` SSR akışında fire-and-forget
// upsert edilir. Recipe.viewCount toplam (all-time) kalırken bu tablo
// gün-gün dağılımı tutar: admin analytics view trend grafiği ve ileride
// "bu hafta en çok okunan" listesi buradan beslenir.
//
// Bucket: (recipeId, date) composite unique; `date` DATE tipi (UTC gün).
// Zaman dilimi kararı: ziyaretçinin lokal TSİ değil sunucu UTC günü
// kullanılır — admin paneli TR saatine hizalamak yerine "son 30 gün trend"
// yeterli ham sinyal veriyor; DST/TZ karmaşasına girmiyoruz.
//
// Prune: yok. Row sayısı ~= tarif sayısı × aktif gün sayısı; 2320 tarif
// × 365 gün = 847k/yıl üst limit (her gün tüm tariflere view vurmaz).
// Ölçek büyürse 180 gün prune cron'u eklenir.
model RecipeViewDaily {
  id       String   @id @default(cuid())
  recipeId String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  // UTC gün — @db.Date ile saat bilgisini düşürüp bucket anahtarı yapar.
  date     DateTime @db.Date
  count    Int      @default(0)

  // (recipeId, date) unique → upsert anahtarı. Aynı gün ikinci ziyaret
  // count+1 eder, yeni row açmaz.
  @@unique([recipeId, date])
  // Trend query: `date >= since GROUP BY date SUM(count)` için date tek
  // başına index yeterli; (recipeId, date) zaten unique'ten composite
  // gelir, per-recipe lookup'ta da kullanılır.
  @@index([date])
  @@map("recipe_view_daily")
}

// Site-wide key/value store — feature flags + config. Announcement model'i
// duyuruları (süreli, sunucudan push edilen banner içeriği) tutarken
// SiteSetting runtime toggle'ları tutar: `userPhotosEnabled`, ileride
// `variationUploadEnabled`, `maintenanceMode` gibi anahtarlar burada yaşar.
// Admin panel'den tek tıkla değişir, unstable_cache 60s TTL ile hot path'lere
// yayılır. Değer her zaman string ("true"/"false" veya JSON payload)
// tutulur; okurken helper cast'ler (`getBooleanSetting`).
model SiteSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  // Kim güncelledi — audit için. User silinirse null kalır (set null).
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Moderasyon statüsü — RecipePhoto için. VISIBLE default (upload direkt
// yayınlanır, auto-approve), HIDDEN admin/owner tarafından gizlenmiş.
// "Pending" yok — spam/uygunsuzluk sonradan hide edilir, pre-moderation
// kuyruğu gereksiz yük.
enum RecipePhotoStatus {
  VISIBLE
  HIDDEN
}

// Kullanıcı tarafından yüklenen tarif fotoğrafı. Cloudinary'de host'lanır;
// `publicId` delete + transformation için referans. `userId` silinirse
// fotoğraf kalır ama anonim görünür (SetNull). `recipeId` silinirse
// fotoğraflar cascade silinir. Feature flag `userPhotosEnabled` kapalıysa
// UI'da gözükmez — public path hem listing hem upload form'u render
// etmez, ama DB'deki mevcut kayıtlar korunur.
model RecipePhoto {
  id           String            @id @default(cuid())
  recipeId     String
  userId       String?
  // Cloudinary secure_url. Resize/thumbnail için URL transformation
  // kullanılabilir (w_300,q_auto,f_auto).
  imageUrl     String            @db.Text
  // Tam çözünürlük (1200w) ve thumbnail (400w) variantları. Detail view
  // orijinali kullanır, grid thumbnail'ı. Cloudinary'nin fetch format
  // transformationları olsa da pre-hesap edip kayda alınca render path
  // ekstra parsing yapmaz.
  thumbnailUrl String?           @db.Text
  // Cloudinary public_id — silerken ve transform URL üretirken.
  publicId     String            @unique @db.VarChar(255)
  width        Int?
  height       Int?
  // İsteğe bağlı başlık — kullanıcı "Ekstra sarımsaklı denedim" gibi not
  // bırakabilir. 200 karakter üst sınır UI seviyesinde validate edilir.
  caption      String?           @db.VarChar(200)
  status       RecipePhotoStatus @default(VISIBLE)
  // Moderasyon bayrakları — ileride auto-flag (NSFW detection) veya user
  // report count. Şimdilik boş kalıyor ama tip + index hazır.
  reportCount  Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Tarif detay sayfası grid için — sadece VISIBLE, oldest-first (olaylık
  // anlatı olsun: ilk deneyen en üstte kalsın).
  @@index([recipeId, status, createdAt])
  // Kullanıcının kendi profilinde "benim fotoğraflarım" listeleme için.
  @@index([userId])
  // Admin moderation queue — yeni gelen fotoğraflar üst sırada.
  @@index([status, createdAt])
  @@map("recipe_photos")
}

// Kullanıcı takip ilişkisi. followerId → followingId'yi takip ediyor.
// Composite unique çift takip kaydını engeller; idempotent toggle için
// followerId + followingId beraber primary lookup key. Cascade: iki taraf
// da silinirse follow da düşer.
//
// Feed query pattern: `WHERE follower.following.followingId IN
// (followed_ids_by_viewer)` → `Variation` ile join. @@index([followingId,
// createdAt]) `/akis` sayfası için "takip edilen X'in takipçi listesi"
// sorgusunu hızlandırır; @@index([followerId, createdAt]) profile
// "takip ediyor" listesi için.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
  @@index([followerId, createdAt])
  @@map("follows")
}

// Kullanıcının "dolabı": evde bulunan malzemeleri kalıcı olarak tutar.
// Oturum 17 sonu eklendi. Amaç:
//   - Cihazlar arası senkron (telefon + bilgisayar aynı dolap)
//   - Son kullanma tarihi bazlı öncelikli tarif önerisi
//   - AI Asistan + v4 menü planlayıcıya tek tık "dolabımı getir"
//   - /dolap sayfasında yönetim (ekle/sil/miktar/tarih)
//
// Tasarım:
//   - ingredientName normalize edilmiş (lowercase TR), unique per user
//   - displayName kullanıcı yazımı ("Tavuk Göğsü" vs)
//   - quantity + unit opsiyonel (kullanıcı sadece "tavuk var" diyebilir)
//   - expiryDate opsiyonel ama girerse son kullanma bildirimi tetikler
//   - Premium tier'da otomatik alışveriş listesi → pantry senkron eklenir
model UserPantryItem {
  id             String    @id @default(cuid())
  userId         String
  // Normalize edilmiş ad (lowercase TR), duplicate önleme için unique key.
  ingredientName String    @db.VarChar(80)
  // Kullanıcıya gösterilen orijinal yazım ("Tavuk Göğsü"). Null ise
  // ingredientName title-case ile fallback.
  displayName    String?   @db.VarChar(100)
  quantity       Decimal?  @db.Decimal(7, 2)
  unit           String?   @db.VarChar(30)
  // Son kullanma tarihi. Null = belirtilmemiş (uyarı tetiklenmez).
  expiryDate     DateTime? @db.Date
  // Opsiyonel user notu ("yarın balık yapacağım", "ikiye bölüp dondurdum").
  note           String?   @db.VarChar(200)
  addedAt        DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Aynı user aynı ingredient'ı iki kere ekleyemez; update ile quantity
  // biriktirilir. Uygulama katmanında upsert pattern.
  @@unique([userId, ingredientName])
  // Son kullanma tarihine göre sort + yaklaşan filtreleme için.
  @@index([userId, expiryDate])
  @@index([userId, addedAt])
  @@map("user_pantry_items")
}
